# ─── OhMyProxy Configuration ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env takes priority over settings.json.

# ─── Proxy ────────────────────────────────────────────────────────────────────
PROXY_HOST=127.0.0.1
PROXY_PORT=8020

# ─── API Keys (comma-separated) ───────────────────────────────────────────────
# Used for dashboard login and proxy API authentication.
API_KEYS=change-me

# ─── Postman Gateway ───────────────────────────────────────────────────────────
POSTMAN_BASE_URL=https://gateway.postman.com
POSTMAN_APP_VERSION=12.14.0
POSTMAN_PLATFORM=DESKTOP_WINDOWS
POSTMAN_MODEL=CLAUDE_OPUS_48_BEDROCK
POSTMAN_USER_ID=
POSTMAN_TEAM_ID=
POSTMAN_WORKSPACE_ID=
POSTMAN_WORKSPACE_NAME=
POSTMAN_FILE_VIEWER_PATH=

# ─── Postman UI Build (auto-detected; rarely changed) ─────────────────────────
POSTMAN_UI_BUILD_DATE=
POSTMAN_UI_BUILD_TIME=
POSTMAN_UI_BUILD_TOOLS_HASH=
POSTMAN_UI_BUILD_KB_HASH=

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_ENABLED=true
LOG_LEVEL=info

# ─── Proxy CWD ─────────────────────────────────────────────────────────────────
POSTMAN_CWD=
