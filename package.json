{
  "name": "postman-claude-proxy",
  "version": "1.0.0",
  "description": "Proxy: Claude Code → Postman Gateway AI (localhost:8020)",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun --watch index.ts",
    "build:css": "bunx tailwindcss -i ./src/dashboard/index.css -o ./src/dashboard/output.css",
    "build:css:min": "bunx tailwindcss -i ./src/dashboard/index.css -o ./src/dashboard/output.css --minify",
    "build:dashboard": "bun build ./src/dashboard/app.tsx --outdir=./src/dashboard/dist --target=browser --minify",
    "prestart": "bun run build:dashboard && bun run build:css",
    "predev": "bun run build:dashboard && bun run build:css",
    "test": "bun test",
    "restart": "bun run restart.ts",
    "setup": "bun run setup.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.0"
  },
  "private": true
}
